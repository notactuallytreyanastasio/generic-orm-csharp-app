@page "{id:int}"
@model ListModel
@{
    ViewData["Title"] = Model.TodoList?.Name ?? "List";
}

@if (Model.TodoList == null)
{
    <div class="win95-window">
        <div class="win95-titlebar">
            <span class="title-text">Error</span>
            <div class="win95-titlebar-buttons">
                <button class="win95-titlebar-btn">X</button>
            </div>
        </div>
        <div class="win95-body" style="text-align:center; padding:24px;">
            <p>List not found.</p>
            <a href="/" class="win95-btn" style="text-decoration:none; display:inline-block; margin-top:8px;">Back to Lists</a>
        </div>
    </div>
}
else
{
    <div class="win95-window">
        <div class="win95-titlebar">
            <span class="title-text">@Model.TodoList.Name</span>
            <div class="win95-titlebar-buttons">
                <button class="win95-titlebar-btn">_</button>
                <button class="win95-titlebar-btn">[]</button>
                <button class="win95-titlebar-btn">X</button>
            </div>
        </div>

        <div class="win95-body">
            <!-- Navigation tabs -->
            <div class="win95-tabs">
                <a href="/" class="win95-tab" style="text-decoration:none;color:inherit;">Lists</a>
                <span class="win95-tab active">@Model.TodoList.Name</span>
                <a href="/Dashboard" class="win95-tab" style="text-decoration:none;color:inherit;">Dashboard</a>
                <a href="/Search" class="win95-tab" style="text-decoration:none;color:inherit;">Search</a>
            </div>

            <div class="win95-tab-content">
                <!-- Validation errors -->
                @if (Model.Errors.Any())
                {
                    <div style="background:#ffe0e0; border:1px solid #cc0000; padding:4px 8px; margin-bottom:8px; font-size:13px;">
                        @foreach (var error in Model.Errors)
                        {
                            <div>@error</div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.TodoList.Description))
                {
                    <div style="padding:4px 8px; font-size:13px; color:var(--win95-btn-shadow); border-bottom:1px solid var(--win95-btn-shadow); margin-bottom:4px;">
                        @Model.TodoList.Description
                    </div>
                }

                <!-- Toolbar (ORM: From, Where, OrderByNulls, NullsLast) -->
                <div class="win95-toolbar">
                    <a href="/" class="win95-btn" style="text-decoration:none; min-width:auto;">&lt; Back</a>
                    <span style="flex:1; font-weight:bold; padding-left:8px;">@Model.TodoList.Name</span>
                    <!-- ORM: Update + Set + Where (compound) -->
                    <form method="post" asp-page-handler="CompleteAll" style="display:inline;">
                        <button type="submit" class="win95-btn" style="min-width:auto;">Mark All Done</button>
                    </form>
                    <!-- ORM: DeleteFrom + Where (multiple) -->
                    <form method="post" asp-page-handler="DeleteCompleted" style="display:inline;">
                        <button type="submit" class="win95-btn danger" style="min-width:auto;"
                                onclick="return confirm('Delete all completed todos?')">Clear Done</button>
                    </form>
                    <span class="lang-badge">C#</span>
                </div>

                <!-- Add Todo Form (ORM: Changeset, ValidateRequired, ValidateLength, ValidateInt, ValidateNumber, ValidateInclusion) -->
                <form method="post" asp-page-handler="AddTodo">
                    <div class="win95-toolbar" style="border-bottom:none; flex-wrap:wrap;">
                        <input type="text" name="Title" class="win95-input" placeholder="Add a new todo..." required style="flex:3; min-width:200px;" />
                        <select name="Priority" class="win95-select" style="flex:0; min-width:100px; width:auto;">
                            <option value="1">P1 Critical</option>
                            <option value="2">P2 High</option>
                            <option value="3" selected>P3 Medium</option>
                            <option value="4">P4 Low</option>
                            <option value="5">P5 Minimal</option>
                        </select>
                        <input type="date" name="DueDate" class="win95-input" style="flex:0; min-width:130px; width:auto;" />
                        <button type="submit" class="win95-btn primary">Add</button>
                    </div>
                </form>

                <!-- Todos Panel -->
                <div class="win95-sunken" style="min-height:200px; max-height:500px;">
                    @if (!Model.TodoList.Todos.Any())
                    {
                        <div style="padding:16px; text-align:center; color:var(--win95-btn-shadow);">
                            No todos yet. Add one above.
                        </div>
                    }
                    else
                    {
                        @foreach (var todo in Model.TodoList.Todos)
                        {
                            <div class="todo-item @(todo.IsCompleted ? "completed" : "")">
                                @if (Model.EditingTodoId == todo.Id)
                                {
                                    <!-- ORM: Changeset, Cast, ValidateRequired, ValidateLength, ValidateInt, ValidateNumber, ToUpdateSql -->
                                    <form method="post" asp-page-handler="UpdateTodo" style="display:flex; align-items:center; gap:8px; flex:1; flex-wrap:wrap;">
                                        <input type="hidden" name="TodoId" value="@todo.Id" />
                                        <input type="text" name="Title" value="@todo.Title" class="win95-input" style="flex:3; min-width:150px;" required autofocus />
                                        <select name="Priority" class="win95-select" style="flex:0; min-width:80px; width:auto;">
                                            @for (int p = 1; p <= 5; p++)
                                            {
                                                if (todo.Priority == p)
                                                {
                                                    <option value="@p" selected>P@p</option>
                                                }
                                                else
                                                {
                                                    <option value="@p">P@p</option>
                                                }
                                            }
                                        </select>
                                        <input type="date" name="DueDate" value="@todo.DueDate" class="win95-input" style="flex:0; min-width:130px; width:auto;" />
                                        <div class="todo-actions">
                                            <button type="submit" class="win95-btn">Save</button>
                                            <a href="/List/@Model.TodoList.Id" class="win95-btn" style="text-decoration:none;">Cancel</a>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <!-- Toggle (ORM: From, Select, Where, Update, Set, ToSql) -->
                                    <form method="post" asp-page-handler="ToggleTodo" style="display:flex; align-items:center;">
                                        <input type="hidden" name="TodoId" value="@todo.Id" />
                                        <input type="checkbox" class="win95-checkbox"
                                               @(todo.IsCompleted ? "checked" : "")
                                               onchange="this.form.submit()" />
                                    </form>

                                    <span class="priority-badge priority-@todo.Priority" title="Priority @todo.Priority: @todo.PriorityLabel">P@todo.Priority</span>

                                    <span class="todo-text">
                                        @todo.Title
                                        @if (todo.DueDate != null)
                                        {
                                            <span class="due-date" style="font-size:12px; color:#666;">[@todo.DueDate]</span>
                                        }
                                    </span>

                                    <!-- Tags (ORM: From, InnerJoin, Where, Col) -->
                                    <span style="display:flex; gap:2px; flex-shrink:0;">
                                        @foreach (var tag in todo.Tags)
                                        {
                                            <span class="tag-badge">
                                                @tag.Name
                                                <!-- ORM: DeleteFrom, Where (multiple AND) -->
                                                <form method="post" asp-page-handler="RemoveTag" style="display:inline;">
                                                    <input type="hidden" name="TodoId" value="@todo.Id" />
                                                    <input type="hidden" name="TagId" value="@tag.Id" />
                                                    <button type="submit" style="background:none; border:none; cursor:pointer; font-size:10px; padding:0; color:#666;">x</button>
                                                </form>
                                            </span>
                                        }
                                    </span>

                                    <div class="todo-actions">
                                        <!-- Tag assignment (ORM: Changeset, ValidateInt, ToInsertSql) -->
                                        @if (Model.AllTags.Any())
                                        {
                                            <form method="post" asp-page-handler="AssignTag" style="display:inline-flex; gap:2px;">
                                                <input type="hidden" name="TodoId" value="@todo.Id" />
                                                <select name="TagId" class="win95-select" style="width:auto; min-width:60px; font-size:12px; padding:1px;">
                                                    @foreach (var tag in Model.AllTags.Where(t => !todo.Tags.Any(tt => tt.Id == t.Id)))
                                                    {
                                                        <option value="@tag.Id">@tag.Name</option>
                                                    }
                                                </select>
                                                <button type="submit" class="win95-btn" style="min-width:auto; padding:1px 4px; font-size:11px;">+Tag</button>
                                            </form>
                                        }
                                        <a href="/List/@Model.TodoList.Id?editTodoId=@todo.Id" class="win95-btn" style="text-decoration:none;">Edit</a>
                                        <!-- ORM: DeleteFrom, Where -->
                                        <form method="post" asp-page-handler="DeleteTodo" style="display:inline;">
                                            <input type="hidden" name="TodoId" value="@todo.Id" />
                                            <button type="submit" class="win95-btn danger"
                                                    onclick="return confirm('Delete this todo?')">Del</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="win95-statusbar">
            <div class="status-section">
                @Model.TodoList.Todos.Count @(Model.TodoList.Todos.Count == 1 ? "item" : "items")
            </div>
            <div class="status-section">
                @Model.TodoList.CompletedCount completed
            </div>
            <div class="status-section">
                @Model.TodoList.RemainingCount remaining
            </div>
        </div>
    </div>
}
