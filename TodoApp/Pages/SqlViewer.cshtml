@page
@model SqlViewerModel
@{
    ViewData["Title"] = "SQL Viewer";
}

<div class="win95-window" style="max-width:900px;">
    <div class="win95-titlebar">
        <span class="title-text">SQL Viewer - ALL ORM Features (@Model.Demos.Count demos)</span>
        <div class="win95-titlebar-buttons">
            <button class="win95-titlebar-btn">_</button>
            <button class="win95-titlebar-btn">[]</button>
            <button class="win95-titlebar-btn">X</button>
        </div>
    </div>

    <div class="win95-body">
        <!-- Navigation tabs -->
        <div class="win95-tabs">
            <a href="/" class="win95-tab" style="text-decoration:none;color:inherit;">Lists</a>
            <a href="/Dashboard" class="win95-tab" style="text-decoration:none;color:inherit;">Dashboard</a>
            <a href="/Search" class="win95-tab" style="text-decoration:none;color:inherit;">Search</a>
            <a href="/Tags" class="win95-tab" style="text-decoration:none;color:inherit;">Tags</a>
            <span class="win95-tab active">SQL Viewer</span>
        </div>

        <div class="win95-tab-content">
            <div style="padding:4px 8px; font-size:13px; background:#fffff0; border:1px solid #ccc; margin-bottom:8px;">
                <strong>Alloy ORM Feature Showcase:</strong> Every SQL statement below is generated by the ORM's
                type-safe query builder. No raw SQL strings -- all values are parameterized via contextual autoescaping.
                This page shows @Model.Demos.Count distinct ORM features.
            </div>

            <div class="win95-sunken" style="max-height:600px;">
                @{ int idx = 0; }
                @foreach (var demo in Model.Demos)
                {
                    idx++;
                    <div style="padding:6px 8px; border-bottom:1px solid #e0e0e0; @(idx % 2 == 0 ? "background:#f8f8f8;" : "")">
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                            <span style="font-size:11px; color:#999; min-width:24px;">@idx.</span>
                            <span class="sql-feature-badge">@demo.Feature</span>
                            <span style="font-size:13px; color:var(--win95-btn-shadow);">@demo.Description</span>
                        </div>
                        <div class="sql-block">@demo.GeneratedSql</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="win95-statusbar">
        <div class="status-section">@Model.Demos.Count ORM features demonstrated</div>
        <div class="status-section">All SQL generated via Alloy ORM</div>
    </div>
</div>
