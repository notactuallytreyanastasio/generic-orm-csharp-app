@{
    /* Retro Mac + Win95 layout - no bootstrap */
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TodoApp (Alloy ORM)</title>
    <link rel="stylesheet" href="~/css/retro.css" />
</head>
<body>
    <!-- Mac System 6 Menu Bar -->
    <div class="mac-menubar">
        <span class="apple-logo">&#63743;</span>
        <a href="/" class="menu-item app-name" style="text-decoration:none;color:inherit;">TodoApp</a>
        <a href="/" class="menu-item" style="text-decoration:none;color:inherit;">Lists</a>
        <a href="/Dashboard" class="menu-item" style="text-decoration:none;color:inherit;">Dashboard</a>
        <a href="/Search" class="menu-item" style="text-decoration:none;color:inherit;">Search</a>
        <a href="/Tags" class="menu-item" style="text-decoration:none;color:inherit;">Tags</a>
        <a href="/SqlViewer" class="menu-item" style="text-decoration:none;color:inherit;">SQL</a>
    </div>

    <!-- Desktop area -->
    <div class="desktop">
        @RenderBody()
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
